        overflow: hidden; 
        width: 100%; 
        border-radius: 8px; 
    }
    #pop-inner-slider, #random-slider-inner { 
        display: flex; 
        transition: transform 0.4s ease; 
        gap: 12px; 
    }
    .slider-item, .pop-slide-item { 
        flex: 0 0 calc(25% - 9px); 
        border-radius: 8px; 
        background: #0a0a0a; 
        overflow: hidden; 
        position: relative; 
        display: flex; 
        flex-direction: column; 
        border: 1px solid #333;
        transition: transform 0.2s;
    }
    .slider-item:hover, .pop-slide-item:hover {
        transform: translateY(-3px);
        border-color: #ffa74e;
    }
    .slider-item img, .pop-slide-item img { 
        width: 100%; 
        aspect-ratio: 2/3;
        object-fit: cover;
        display: block; 
        background: #222; 
    }
    .pop-view-badge { 
        position: absolute; 
        top: 8px; 
        left: 8px; 
        background: #ff2d55; 
        color: #fff; 
