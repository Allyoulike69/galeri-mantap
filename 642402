  <script>
    // ========= KONFIGURASI =========
    const DATA_URL = "https://allyoulike69.github.io/galeri-mantap/daftar.json";
    const BASE_URL = "https://allyoulike69.github.io/galeri-mantap/";
    
    let allPages = [];           // Semua data dari daftar.json
    let filteredPages = [];      // Hasil pencarian
    let isSearchMode = false;
    let currentSearchQuery = "";
    let currentPageNum = 1;
    const itemsPerPage = 25;
    
    // Variabel untuk slider
    let currentPos = 0, popCurrentPos = 0;
    
    // ========= FORMAT TANGGAL =========
    function formatDate(dateStr) {
        if (!dateStr) return "";
        try {
            let date = new Date(dateStr);
            if (isNaN(date.getTime())) return "";
            return `${date.getDate().toString().padStart(2,'0')}/${(date.getMonth()+1).toString().padStart(2,'0')}/${date.getFullYear()}`;
        } catch(e) {
            return "";
        }
    }
    
    // ========= LOAD DATA DARI daftar.json =========
    async function loadData() {
        try {
            document.getElementById('pop-inner-slider').innerHTML = '<div style="grid-column:1/-1; text-align:center; padding:50px;">⏳ Memuat data...</div>';
            document.getElementById('random-slider-inner').innerHTML = '<div style="grid-column:1/-1; text-align:center; padding:50px;">⏳ Memuat data...</div>';
            
            const response = await fetch(DATA_URL);
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            const data = await response.json();
            
            allPages = data.pages || [];
            
            // Urutkan berdasarkan tanggal (terbaru di depan)
            allPages.sort((a, b) => {
                if (!a.date && !b.date) return 0;
                if (!a.date) return 1;
                if (!b.date) return -1;
                return new Date(b.date) - new Date(a.date);
            });
            
            if (allPages.length === 0) {
                document.getElementById('pop-inner-slider').innerHTML = '<div style="grid-column:1/-1; text-align:center; padding:50px;">📭 Belum ada data. Silakan isi daftar.json</div>';
                document.getElementById('random-slider-inner').innerHTML = '<div style="grid-column:1/-1; text-align:center; padding:50px;">📭 Belum ada data</div>';
                return;
            }
            
            // Render kedua slider
            renderNewUpdateSlider();
            renderRecommendedSlider();
            
        } catch (error) {
            console.error('Error loading data:', error);
            document.getElementById('pop-inner-slider').innerHTML = `<div style="grid-column:1/-1; text-align:center; padding:50px;">❌ Gagal memuat daftar.json<br>Pastikan file ada di: ${DATA_URL}</div>`;
            document.getElementById('random-slider-inner').innerHTML = `<div style="grid-column:1/-1; text-align:center; padding:50px;">❌ Gagal memuat daftar.json</div>`;
        }
    }
    
    // ========= RENDER NEW UPDATE SLIDER (semua item, urut terbaru) =========
    function renderNewUpdateSlider() {
        const container = document.getElementById('pop-inner-slider');
        container.innerHTML = "";
        
        if (!allPages.length) return;
        
        // Tampilkan semua item (atau batasi 20 untuk performa slider)
        const itemsToShow = allPages.slice(0, 20);
        
        itemsToShow.forEach((item, index) => {
            let link = item.link.startsWith('http') ? item.link : BASE_URL + item.link;
            let imgUrl = item.image || "https://placehold.co/400x600?text=No+Image";
            let title = item.title || "Untitled";
            let dateStr = formatDate(item.date);
            let dateBadge = dateStr ? `<span style="position:absolute; bottom:5px; right:5px; background:rgba(0,0,0,0.7); color:#ffa74e; font-size:9px; padding:2px 5px; border-radius:3px;"><i class="fa-regular fa-calendar"></i> ${dateStr}</span>` : "";
            
            container.innerHTML += `
                <div class="pop-slide-item">
                    <div class="pop-view-badge"><i class="fa-regular fa-clock"></i> NEW</div>
                    ${dateBadge}
                    <a href="${link}"><img src="${imgUrl}" onerror="this.src='https://placehold.co/400x600?text=Error'" loading="lazy"></a>
                    <a class="pop-slide-title" href="${link}">${escapeHtml(title)}</a>
                </div>
            `;
        });
        
        // Reset posisi slider
        popCurrentPos = 0;
        const inner = document.getElementById('pop-inner-slider');
        if(inner) inner.style.transform = 'translateX(0px)';
    }
    
    // ========= RENDER RECOMMENDED SLIDER (5 item random) =========
    function renderRecommendedSlider() {
        const container = document.getElementById('random-slider-inner');
        container.innerHTML = "";
        
        if (!allPages.length) return;
        
        // Acak dan ambil 5 item
        let shuffled = [...allPages];
        for (let i = shuffled.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }
        const selected = shuffled.slice(0, 5);
        
        selected.forEach((item) => {
            let link = item.link.startsWith('http') ? item.link : BASE_URL + item.link;
            let imgUrl = item.image || "https://placehold.co/400x600?text=No+Image";
            let title = item.title || "Untitled";
            
            container.innerHTML += `
                <div class="slider-item">
                    <a href="${link}"><img src="${imgUrl}" onerror="this.src='https://placehold.co/400x600?text=Error'" loading="lazy"></a>
                    <a class="slider-title" href="${link}">${escapeHtml(title)}</a>
                </div>
            `;
        });
        
        // Reset posisi slider
        currentPos = 0;
        const inner = document.getElementById('random-slider-inner');
        if(inner) inner.style.transform = 'translateX(0px)';
    }
    
    // ========= FUNGSI SLIDER NAVIGASI =========
    function moveSlide(dir) {
        const inner = document.getElementById('random-slider-inner');
        const item = document.querySelector('.slider-item');
        if(!item || !inner) return;
        const itemWidth = item.offsetWidth + 12;
        currentPos -= (dir * itemWidth);
        if (currentPos > 0) currentPos = 0;
        const max = inner.scrollWidth - document.getElementById('slider-viewport').offsetWidth;
        if (Math.abs(currentPos) > max) currentPos = -max;
        inner.style.transform = 'translateX(' + currentPos + 'px)';
    }
    
    function movePopSlide(dir) {
        const inner = document.getElementById('pop-inner-slider');
        const item = document.querySelector('.pop-slide-item');
        if(!item || !inner) return;
        const itemWidth = item.offsetWidth + 12;
        popCurrentPos -= (dir * itemWidth);
        if (popCurrentPos > 0) popCurrentPos = 0;
        const max = inner.scrollWidth - document.getElementById('pop-viewport').offsetWidth;
        if (Math.abs(popCurrentPos) > max) popCurrentPos = -max;
        inner.style.transform = 'translateX(' + popCurrentPos + 'px)';
    }
    
    // ========= FUNGSI PENCARIAN =========
    function performSearch(query) {
        if (!query.trim()) {
            resetToHome();
            return;
        }
        
        isSearchMode = true;
        currentSearchQuery = query;
        
        filteredPages = allPages.filter(item => {
            const title = (item.title || "").toLowerCase();
            return title.includes(query.toLowerCase());
        });
        
        // Sembunyikan slider
        document.getElementById('new-update-section').style.display = 'none';
        document.getElementById('recommended-section').style.display = 'none';
        document.getElementById('comic-gallery').style.display = 'none';
        
        // Tampilkan hasil pencarian
        const searchContainer = document.createElement('div');
        searchContainer.id = 'search-results';
        searchContainer.className = 'comic-grid';
        searchContainer.style.marginTop = '20px';
        
        const oldSearch = document.getElementById('search-results');
        if (oldSearch) oldSearch.remove();
        
        if (filteredPages.length === 0) {
            searchContainer.innerHTML = `<div style="grid-column:1/-1; text-align:center; padding:50px;">🔍 Tidak ada komik dengan judul "${query}"</div>`;
        } else {
            filteredPages.forEach((item) => {
                let link = item.link.startsWith('http') ? item.link : BASE_URL + item.link;
                let imgUrl = item.image || "https://placehold.co/400x600?text=No+Image";
                let title = item.title || "Untitled";
                let dateStr = formatDate(item.date);
                let dateBadge = dateStr ? `<span class="date-badge" style="position:absolute; bottom:5px; right:5px; background:rgba(0,0,0,0.7); color:#ffa74e; font-size:9px; padding:2px 5px; border-radius:3px;"><i class="fa-regular fa-calendar"></i> ${dateStr}</span>` : "";
                
                searchContainer.innerHTML += `
                    <div class="comic-item">
                        <span class="badge badge-new" style="top:5px; left:5px; background:#b80006;">NEW</span>
                        ${dateBadge}
                        <a href="${link}"><div class="comic-thumb-container"><img src="${imgUrl}" class="comic-thumb" loading="lazy" onerror="this.src='https://placehold.co/400x600?text=Error'"></div></a>
                        <a class="comic-title" href="${link}">${escapeHtml(title)}</a>
                    </div>
                `;
            });
        }
        
        document.getElementById('main-content').appendChild(searchContainer);
        document.getElementById('new-section')?.scrollIntoView({ behavior: 'smooth' });
    }
    
    function resetToHome() {
        isSearchMode = false;
        currentSearchQuery = "";
        
        // Tampilkan kembali slider
        document.getElementById('new-update-section').style.display = 'block';
        document.getElementById('recommended-section').style.display = 'block';
        document.getElementById('comic-gallery').style.display = 'flex';
        
        // Hapus hasil pencarian
        const oldSearch = document.getElementById('search-results');
        if (oldSearch) oldSearch.remove();
        
        // Refresh slider (Recommended di-random ulang)
        renderRecommendedSlider();
        
        // Reset posisi slider
        currentPos = 0;
        popCurrentPos = 0;
        const randomInner = document.getElementById('random-slider-inner');
        const popInner = document.getElementById('pop-inner-slider');
        if(randomInner) randomInner.style.transform = 'translateX(0px)';
        if(popInner) popInner.style.transform = 'translateX(0px)';
    }
    
    // ========= MANGA READER (dari raw-links) =========
    let currentImages = [];
    let currentIndex = 0;
    let zoomLevel = 1.0;
    let maxZoom = 3.0;

    function updateMaxZoom() {
        maxZoom = window.innerWidth <= 1280 ? 2.0 : 3.0;
    }

    function initGallery() {
        const rawLinksEl = document.getElementById('raw-links');
        const gallery = document.getElementById('comic-gallery');
        
        currentImages = rawLinksEl.innerText.split(/\s+/).filter(u => u.startsWith("http"));
        
        currentImages.forEach((url, index) => {
            const img = document.createElement('img');
            img.src = url;
            img.loading = "lazy";
            img.onclick = () => openReader(index);
            gallery.appendChild(img);
        });
    }

    function openReader(index) {
        currentIndex = index;
        zoomLevel = 1.0;
        updateMaxZoom();
        document.getElementById('manga-reader').style.display = 'flex';
        showCurrentPage();
    }

    function showCurrentPage() {
        const img = document.getElementById('reader-image');
        img.src = currentImages[currentIndex];
        img.style.transform = `scale(${zoomLevel})`;
        const pageText = `${currentIndex + 1} of ${currentImages.length}`;
        document.getElementById('page-counter').textContent = pageText;
        document.getElementById('page-counter-bottom').textContent = pageText;
        document.getElementById('zoom-level').textContent = zoomLevel.toFixed(1) + "x";
        document.getElementById('zoom-level-bottom').textContent = zoomLevel.toFixed(1) + "x";
    }

    function nextPage() { if (currentIndex < currentImages.length - 1) { currentIndex++; showCurrentPage(); } }
    function prevPage() { if (currentIndex > 0) { currentIndex--; showCurrentPage(); } }
    function firstPage() { currentIndex = 0; showCurrentPage(); }
    function lastPage() { currentIndex = currentImages.length - 1; showCurrentPage(); }

    function zoomIn() {
        updateMaxZoom();
        zoomLevel = Math.min(maxZoom, zoomLevel + 0.25);
        document.getElementById('reader-image').style.transform = `scale(${zoomLevel})`;
        document.getElementById('zoom-level').textContent = zoomLevel.toFixed(1) + "x";
        document.getElementById('zoom-level-bottom').textContent = zoomLevel.toFixed(1) + "x";
    }

    function zoomOut() {
        zoomLevel = Math.max(1.0, zoomLevel - 0.25);
        document.getElementById('reader-image').style.transform = `scale(${zoomLevel})`;
        document.getElementById('zoom-level').textContent = zoomLevel.toFixed(1) + "x";
        document.getElementById('zoom-level-bottom').textContent = zoomLevel.toFixed(1) + "x";
    }

    function closeReader() {
        document.getElementById('manga-reader').style.display = 'none';
    }

    document.addEventListener('keydown', function(e) {
        if (document.getElementById('manga-reader').style.display === 'flex') {
            if (e.key === "ArrowRight") nextPage();
            if (e.key === "ArrowLeft") prevPage();
            if (e.key === "Escape") closeReader();
        }
    });
    
    function escapeHtml(str) {
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
    // ========= EVENT LISTENER =========
    document.addEventListener("DOMContentLoaded", function() {
        // Load data dari daftar.json
        loadData();
        
        // Init gallery manga reader
        initGallery();
        
        // DESKTOP SEARCH
        const searchBtnDesktop = document.getElementById('searchBtnDesktop');
        const searchInputDesktop = document.getElementById('searchInputDesktop');
        
        // MOBILE SEARCH
        const searchIconMobile = document.getElementById('searchIconMobile');
        const mobileOverlay = document.getElementById('mobileSearchOverlay');
        const closeSearchBtn = document.getElementById('closeSearchBtn');
        const searchBtnMobile = document.getElementById('searchBtnMobile');
        const searchInputMobile = document.getElementById('searchInputMobile');
        
        if(searchBtnDesktop) {
            searchBtnDesktop.addEventListener('click', function(e) {
                e.preventDefault();
                performSearch(searchInputDesktop.value.trim());
            });
        }
        if(searchInputDesktop) {
            searchInputDesktop.addEventListener('keypress', function(e) {
                if(e.key === 'Enter') {
                    e.preventDefault();
                    performSearch(searchInputDesktop.value.trim());
                }
            });
        }
        
        if(searchIconMobile) {
            searchIconMobile.addEventListener('click', function() {
                mobileOverlay.style.display = 'block';
                setTimeout(() => searchInputMobile.focus(), 100);
            });
        }
        
        if(closeSearchBtn) {
            closeSearchBtn.addEventListener('click', function() {
                mobileOverlay.style.display = 'none';
                searchInputMobile.value = '';
            });
        }
        
        if(searchBtnMobile) {
            searchBtnMobile.addEventListener('click', function() {
                const query = searchInputMobile.value.trim();
                mobileOverlay.style.display = 'none';
                performSearch(query);
                if(searchInputDesktop) searchInputDesktop.value = query;
            });
        }
        
        if(searchInputMobile) {
            searchInputMobile.addEventListener('keypress', function(e) {
                if(e.key === 'Enter') {
                    e.preventDefault();
                    const query = searchInputMobile.value.trim();
                    mobileOverlay.style.display = 'none';
                    performSearch(query);
                    if(searchInputDesktop) searchInputDesktop.value = query;
                }
            });
        }
        
        // Navigasi header
        document.getElementById('navHome').addEventListener('click', function(e) {
            e.preventDefault();
            resetToHome();
            if(mobileOverlay) mobileOverlay.style.display = 'none';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        document.getElementById('navNew').addEventListener('click', function(e) {
            e.preventDefault();
            resetToHome();
            document.getElementById('new-update-section')?.scrollIntoView({ behavior: 'smooth' });
            if(mobileOverlay) mobileOverlay.style.display = 'none';
        });
        document.getElementById('navRecommended').addEventListener('click', function(e) {
            e.preventDefault();
            resetToHome();
            document.getElementById('recommended-section')?.scrollIntoView({ behavior: 'smooth' });
            if(mobileOverlay) mobileOverlay.style.display = 'none';
        });
        document.getElementById('logoClick').addEventListener('click', function() {
            resetToHome();
            if(mobileOverlay) mobileOverlay.style.display = 'none';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    });
  </script>
</body>
