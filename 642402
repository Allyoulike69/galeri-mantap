          font-size: 22px;
          cursor: pointer;
          padding: 8px;
      }
      
      .search-panel-desktop {
          display: flex;
          align-items: center;
          background: #222;
          border-radius: 40px;
          padding: 5px 15px;
          border: 1px solid #444;
